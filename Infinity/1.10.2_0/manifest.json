{
   "action": {
      "default_icon": {
         "128": "images/icon-128.png",
         "16": "images/icon-16.png",
         "32": "images/icon-32.png",
         "48": "images/icon-48.png"
      },
      "default_popup": "pages/popup.html"
   },
   "background": {
      "service_worker": "bundles/background.js",
      "type": "module"
   },
   "content_scripts": [ {
      "js": [ "bundles/content.js" ],
      "matches": [ "https://*.feishu.cn/*", "https://*.feishu.net/*", "https://*.larksuite.com/*", "https://*.feishu-pre.net/*", "https://*.larkoffice.com/*", "https://*.larkenterprise.com/*" ],
      "run_at": "document_end"
   } ],
   "default_locale": "en",
   "description": "Convert lark cloud documents to markdown",
   "host_permissions": [ "https://*.feishu.cn/*", "https://*.feishu.net/*", "https://*.larksuite.com/*", "https://*.feishu-pre.net/*", "https://*.larkoffice.com/*", "https://*.larkenterprise.com/*" ],
   "icons": {
      "128": "images/icon-128.png",
      "16": "images/icon-16.png",
      "32": "images/icon-32.png",
      "48": "images/icon-48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Cloud Document Converter",
   "options_page": "pages/options.html",
   "permissions": [ "contextMenus", "scripting", "storage" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.10.2"
}
